# .env.example
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control — it contains secrets.
# .env is already listed in .gitignore.
#
# -----------------------------------------------------------------------------
# Supabase
# Find both values at: Supabase dashboard > Settings > API
# -----------------------------------------------------------------------------

# Project URL — Supabase dashboard > Settings > API > Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key — same page, "anon public" key under "Project API keys"
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# -----------------------------------------------------------------------------
# Azure Static Web Apps
# Find this value at: Azure portal > your Static Web App resource > Overview >
# Manage deployment token
# -----------------------------------------------------------------------------

AZURE_STATIC_WEB_APPS_API_TOKEN=your-azure-static-web-apps-deployment-token-here

# -----------------------------------------------------------------------------
# Microsoft Entra ID (Azure Active Directory)
# Find these values at: Entra ID > App registrations > your app
# -----------------------------------------------------------------------------

# Application (client) ID — Overview tab
AAD_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Client secret Value — Certificates & secrets > Client secrets > Value
# This value is shown ONLY ONCE when the secret is created. Store it immediately.
AAD_CLIENT_SECRET=your-client-secret-value-shown-only-once
